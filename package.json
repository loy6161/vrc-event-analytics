{
  "name": "vrc-event-analytics",
  "version": "1.0.0",
  "type": "module",
  "description": "VRChat event analytics dashboard with YouTube integration",
  "main": "server/index.ts",
  "scripts": {
    "dev": "concurrently \"vite\" \"node --import tsx server/index.ts\"",
    "build": "vite build",
    "build:full": "npm run type-check && npm run build",
    "preview": "vite preview",
    "server": "node --import tsx server/index.ts",
    "start": "cross-env NODE_ENV=production node --import tsx server/index.ts",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test tests/integration.test.mjs"
  },
  "dependencies": {
    "@esbuild/win32-x64": "^0.27.4",
    "@libsql/client": "^0.17.2",
    "@tanstack/react-table": "^8.17.3",
    "better-sqlite3": "^9.2.2",
    "chokidar": "^3.6.0",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "file-saver": "^2.0.5",
    "googleapis": "^118.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.10.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.5",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.4.10"
  }
}
